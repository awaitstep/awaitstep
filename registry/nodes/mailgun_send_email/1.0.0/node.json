{
  "id": "mailgun_send_email",
  "name": "Mailgun Send Email",
  "version": "1.0.0",
  "description": "Sends an email via the Mailgun API",
  "category": "Email",
  "icon": "https://cdn.simpleicons.org/mailgun",
  "tags": ["email", "mailgun", "transactional"],
  "author": "awaitstep",
  "license": "Apache-2.0",
  "configSchema": {
    "from": {
      "type": "string",
      "label": "From",
      "required": true,
      "placeholder": "you@yourdomain.com",
      "description": "Sender email address. Must be from a verified Mailgun domain."
    },
    "to": {
      "type": "string",
      "label": "To",
      "required": true,
      "placeholder": "recipient@example.com",
      "description": "Recipient email address."
    },
    "subject": {
      "type": "string",
      "label": "Subject",
      "required": true,
      "placeholder": "Hello from AwaitStep"
    },
    "html": {
      "type": "textarea",
      "label": "HTML Body",
      "required": true,
      "description": "Email body as HTML."
    },
    "cc": {
      "type": "string",
      "label": "CC",
      "placeholder": "cc@example.com"
    },
    "bcc": {
      "type": "string",
      "label": "BCC",
      "placeholder": "bcc@example.com"
    },
    "domain": {
      "type": "string",
      "label": "Domain",
      "required": true,
      "placeholder": "mg.yourdomain.com",
      "description": "Your Mailgun sending domain."
    },
    "apiKey": {
      "type": "secret",
      "label": "Mailgun API Key",
      "required": true,
      "envVarName": "MAILGUN_API_KEY",
      "description": "Found in your Mailgun dashboard under API Keys."
    }
  },
  "outputSchema": {
    "id": {
      "type": "string",
      "description": "Mailgun message ID"
    }
  },
  "providers": ["cloudflare"],
  "runtime": {
    "defaultRetries": 3,
    "defaultTimeout": "30 seconds",
    "idempotent": false
  }
}
