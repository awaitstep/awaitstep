# Security
TOKEN_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:8080

# OAuth - GitHub (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth - Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App
APP_NAME=awaitstep-worker

# Server
PORT=8080
NODE_ENV=development


# PostgreSQL (for self-hosted, leave empty for SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/awaitstep
