{
  "name": "@awaitstep/db",
  "version": "1.4.5-beta.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate && DB_DIALECT=pg drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "@awaitstep/tsconfig": "workspace:*",
    "drizzle-kit": "^0.31.9",
    "tsup": "8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
