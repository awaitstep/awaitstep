{
  "name": "@awaitstep/codegen",
  "version": "1.4.13",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./transpile": {
      "types": "./dist/transpile.d.ts",
      "import": "./dist/transpile.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@awaitstep/tsconfig": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@awaitstep/ir": "workspace:*",
    "sucrase": "^3.35.1"
  }
}
