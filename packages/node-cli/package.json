{
  "name": "@awaitstep/node-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "awaitstep-node": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@awaitstep/ir": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@awaitstep/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "tsup": "8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
