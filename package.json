{
  "name": "awaitstep",
  "version": "1.4.5-beta.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "dotenv -- turbo run build",
    "dev": "dotenv -- turbo run dev",
    "web:dev": "dotenv -- turbo run dev --filter=@awaitstep/web...",
    "test": "dotenv -- turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "dotenv -- pnpm --filter @awaitstep/db db:generate",
    "db:migrate": "dotenv -- pnpm --filter @awaitstep/db db:migrate",
    "db:push": "dotenv -- pnpm --filter @awaitstep/db db:push",
    "nodes:generate": "turbo run build --filter=@awaitstep/node-cli... && node packages/node-cli/dist/cli.js generate",
    "nodes:build": "turbo run build --filter=@awaitstep/node-cli... && node packages/node-cli/dist/cli.js build",
    "prebuild": "pnpm nodes:build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "h3": ">=2.0.1-rc.19",
      "h3-v2": "npm:h3@>=2.0.1-rc.19",
      "defu": ">=6.1.5",
      "dompurify": ">=3.3.3",
      "lodash-es": ">=4.18.1"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "9.1.7",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
